{
  "name": "edubridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "next dev --turbo",
    "build": "next build",
    "build:analyze": "set ANALYZE=true && next build",
    "build:optimize": "bash scripts/add-dynamic-config.sh && next build",
    "build:segment-config": "bash scripts/setup-segment-configs.sh && next build",
    "build:optimized": "NODE_ENV=production bash scripts/improved-segment-configs.sh && next build",
    "start": "next start",
    "lint": "next lint --fix",
    "prebuild": "echo 'Type-check and lint run during next build'",
    "predeploy": "npm run lint && npm run prebuild && next build",
    "db:migrate": "node scripts/apply-migration.mjs",
    "db:migrate:admin": "node scripts/apply-migration.mjs admin-migration.sql",
    "db:test": "node scripts/test_quiz_attempts_table.mjs",
    "migrate:app-router": "node scripts/migrate-to-app-router.mjs",
    "test": "npx jest --config config/jest.config.mjs",
    "test:watch": "npx jest --config config/jest.config.mjs --watch",
    "test:coverage": "npx jest --config config/jest.config.mjs --coverage"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-query": "^5.101.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.5.0",
    "lucide-react": "^0.503.0",
    "next": "15.5.19",
    "pg": "^8.22.0",
    "postcss-cli": "^11.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^29.7.0",
    "@next/bundle-analyzer": "^15.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@types/testing-library__jest-dom": "^6.0.0",
    "autoprefixer": "^10.5.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "supabase": "^2.107.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "whatwg-fetch": "^3.6.20"
  }
}
